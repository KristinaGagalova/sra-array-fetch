#!/bin/bash
#SBATCH --job-name=__JOB_NAME__
#SBATCH --account=__ACCOUNT__
#SBATCH --array=__ARRAY_RANGE__
#SBATCH --cpus-per-task=__CPUS__
#SBATCH --mem=__MEM__
#SBATCH --time=__WALLTIME__
#SBATCH --output=__LOG_DIR__/sra_%A_%a.out
#SBATCH --error=__LOG_DIR__/sra_%A_%a.err
#
# Auto-generated by `sra-array submit` -- do not edit by hand, edit the CLI
# invocation instead and re-run `sra-array submit`.
#
# All actual work (accession lookup, sra-tools install-if-missing, download,
# conversion, compression) lives in the sra_array_fetch Python package so it
# stays testable outside of SLURM. This script is intentionally a thin shim.

set -euo pipefail

# Make sure the compute node can `import sra_array_fetch` regardless of
# whether this job inherited PYTHONPATH from the submitting shell (many
# clusters do not guarantee this). The path below is the directory
# containing the sra_array_fetch package (its parent), computed at submit
# time from wherever `sra-array` was actually running from.
export PYTHONPATH="__PACKAGE_PARENT_DIR__${PYTHONPATH:+:$PYTHONPATH}"

exec __PYTHON__ -m sra_array_fetch run-task \
  --ids "__IDS__" \
  --outdir "__OUTDIR__" \
  --sra-cache "__SRACACHE__" \
  --tools-dir "__TOOLS_DIR__" \
  --max-size "__MAX_SIZE__"
